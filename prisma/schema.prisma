generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  username  String    @unique
  password  String
  profile   Profile?
  createdAt DateTime  @default(now())
}

model Profile {
  id        String       @id @default(cuid())
  userId    String       @unique
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  headline  String       @default("")
  photo     String       @default("")
  education Education[]
  skills    Skill[]
  experience Experience[]
  documents Document[]
  socialLinks SocialLink[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model Education {
  id        String  @id @default(cuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  school    String
  major     String
  year      String
}

model Skill {
  id        String  @id @default(cuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name      String
}

model Experience {
  id          String  @id @default(cuid())
  profileId   String
  profile     Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  company     String
  position    String
  year        String
  description String  @default("")
}

model Document {
  id        String  @id @default(cuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  label     String
  url       String
}

model SocialLink {
  id        String  @id @default(cuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  platform  String
  url       String
}
